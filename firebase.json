{
  "hosting": {
    "public": "dist/recruitment-quiz",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/da/{,/**}",
        "destination": "/da/index.html"
      },
      {
        "source": "/en/{,/**}",
        "destination": "/en/index.html"
      }
    ],
    "i18n": {
      "root": "/"
    }
  },
  "functions": {
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  }
}
