{
  "hosting": {
    "public": "dist/recruitment-quiz",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/da-DK/{,/**}",
        "destination": "/da-DK/index.html"
      },
      {
        "source": "/en-US/{,/**}",
        "destination": "/en-US/index.html"
      }
    ],
    "i18n": {
      "root": "/"
    }
  },
  "functions": {
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  }
}
